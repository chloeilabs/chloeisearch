# Copy to .env.local and fill in. Server-side only — never expose via NEXT_PUBLIC_*.
# Brave sells each endpoint as a separate subscription (web search, autosuggest,
# spellcheck, AI answers). Optional keys fall back to BRAVE_API_KEY; if that key
# lacks the subscription, the feature degrades gracefully (suggest → local
# history; spellcheck/answers → hidden).
BRAVE_API_KEY=your-api-key-here
BRAVE_SUGGEST_API_KEY=
BRAVE_SPELLCHECK_API_KEY=
BRAVE_ANSWERS_API_KEY=

# Optional: 1 = serve canned fixtures instead of calling Brave (protects quota during development)
BRAVE_MOCK=1
