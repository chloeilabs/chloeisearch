DATABASE_URL="postgresql://chloei:chloei@localhost:55432/chloei_code?schema=public"
CURSOR_API_KEY="key_xxx"
AUTH_SECRET="replace-with-a-random-secret"
AUTH_GITHUB_ID="github-oauth-client-id"
AUTH_GITHUB_SECRET="github-oauth-client-secret"
# GitHub OAuth requests read:user, user:email, repo, and read:org so the
# server can populate the repository selector from the signed-in user's account.

# Optional local-only bypass for development without OAuth.
ALLOW_DEV_AUTH_BYPASS="false"

# Optional defaults and production controls.
DEFAULT_CURSOR_MODEL=""
ALLOWED_GIT_HOSTS="github.com"
ALLOWED_GITHUB_ORGS=""
ALLOWED_GITHUB_USERS=""
ALLOWED_EMAILS=""
AGENT_RUN_RATE_LIMIT="10"
AGENT_RUN_ACTIVE_LIMIT="3"
AGENT_RUN_DAILY_LIMIT="25"
CRON_REFRESH_BATCH_SIZE="10"
STALE_ACTIVE_RUN_MINUTES="15"
CRON_SECRET=""
