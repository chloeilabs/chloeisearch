generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  agentRuns     AgentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model AgentRun {
  id               String  @id @default(cuid())
  userId           String
  cursorAgentId    String?
  cursorRunId      String?
  repoUrl          String
  startingRef      String
  taskPrompt       String
  taskSummary      String
  modelId          String?
  runtime          String  @default("cloud")
  autoCreatePR     Boolean @default(true)
  normalizedStatus String
  rawCursorStatus  String?
  prUrl            String?
  branchName       String?
  resultSummary    String?
  resultRawPayload Json?
  errorMessage     String?
  idempotencyKey   String  @unique

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?

  retryOfRunId String?
  retryOfRun   AgentRun?  @relation("AgentRunRetries", fields: [retryOfRunId], references: [id], onDelete: SetNull)
  retries      AgentRun[] @relation("AgentRunRetries")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  events    AgentRunEvent[]
  artifacts AgentRunArtifact[]

  @@index([userId])
  @@index([normalizedStatus])
  @@index([createdAt])
  @@index([cursorAgentId])
  @@index([cursorRunId])
  @@index([repoUrl])
}

model AgentRunEvent {
  id             String   @id @default(cuid())
  agentRunId     String
  sequenceNumber Int
  eventType      String
  messageText    String?
  rawPayload     Json
  createdAt      DateTime @default(now())

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, sequenceNumber])
  @@index([createdAt])
}

model AgentRunArtifact {
  id         String   @id @default(cuid())
  agentRunId String
  artifactId String
  name       String
  mimeType   String?
  size       Int?
  previewUrl String?
  rawPayload Json
  createdAt  DateTime @default(now())

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId])
  @@index([artifactId])
}
